# Telegram API credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# Your Telegram user ID (the assistant needs to know which messages are yours).
# Run `python -c "from telethon.sync import TelegramClient; import os; c=TelegramClient('session', int(os.environ['TELEGRAM_API_ID']), os.environ['TELEGRAM_API_HASH']); c.start(); print(c.get_me().id)"`
TELEGRAM_USER_ID=

# OpenRouter API key for transcription, fact extraction, and query answering
# Get one for free: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter LLM model for fact/event extraction and chat answers
# gemini-2.5-flash: best price/quality for structured extraction (~$0.10/M in, $0.40/M out)
# For free alternatives: https://openrouter.ai/models?max_price=0
OPENROUTER_LLM_MODEL=google/gemini-2.5-flash

# Override for the assistant's reply generator. Defaults to OPENROUTER_LLM_MODEL if unset.
ASSISTANT_LLM_MODEL=

# Style profiler (scripts/extract_style_profile.py): LLM for the B/C/D layers.
STYLE_LLM_MODEL=deepseek/deepseek-v4-flash
# Hard-pin one OpenRouter provider so the prompt cache is reused across re-runs
# (caching is node-local; load-balancing across providers defeats it). Leave
# empty to let OpenRouter load-balance (no reliable caching).
STYLE_LLM_PROVIDER=DeepInfra

# --- Style imitation in the live assistant (src/agent) ---
# STYLE_ENABLED=0 disables persona + few-shot (plain generator).
STYLE_ENABLED=1
# Path to the persona profile (extract_style_profile.py output).
# Empty => auto-pick the latest *.style.json in the project root.
STYLE_PROFILE_FILE=
# How many (incoming -> your-reply) few-shot examples to retrieve per message.
STYLE_FEWSHOT_K=6
# Retrieve style examples across all chats (the fact-redacted bank is safe to
# share between chats). 0 = restrict few-shot to the current chat only.
STYLE_CROSS_CHAT=1

# Local sentence-transformers embedding model (good for Russian)
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Qdrant connection
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=tg_chat
STYLE_COLLECTION=tg_style

# Local Ollama inference (used by `python scripts/query.py --llm ollama`)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Assistant behavior
# ASSISTANT_DEFAULT_MODE: what to do when the incoming chat is NOT in whitelist.json
#   - "ignore": do nothing
#   - "suggest": drop a draft into Saved Messages, never auto-send
ASSISTANT_DEFAULT_MODE=ignore

# How many recent messages from the current chat to include as live context
ASSISTANT_HISTORY_DEPTH=10

# Path to whitelist file (relative to project root)
WHITELIST_FILE=whitelist.json

# Directory with per-chat markdown system-prompts.
# File names: @username.md (case-insensitive), <chat_id>.md, or _default.md as fallback.
CHAT_PROMPTS_DIR=chat_prompts

# Aiogram control bot — create one with @BotFather, paste token here.
# This bot is where draft replies appear with Approve / Edit / Skip buttons.
BOT_TOKEN=

# Your Telegram user ID (numeric). The bot only accepts approvals from this user.
# Same as TELEGRAM_USER_ID above; kept separate for clarity.
BOT_OWNER_ID=

# How long a pending draft stays valid before auto-expiring (seconds).
DRAFT_TTL_SECONDS=3600

# Per-chat working memory (conversation context summarization)
# Directory for context files (relative to project root, starts with dot)
# WORKING_MEMORY_DIR=.chat_contexts
# Max tokens of chat history to fetch when building initial memory
# WORKING_MEMORY_MAX_TOKENS=4000
# Seconds to wait for follow-up messages before invoking the agent
# (batches "split-thought" messages into one LLM call)
# MESSAGE_DEBOUNCE_SECONDS=6

# Smart debounce: if consecutive messages arrive faster than FAST_GAP seconds,
# the wait extends to EXTENDED seconds. HARD_CAP is the absolute max wait.
# DEBOUNCE_FAST_GAP=2.0
# DEBOUNCE_EXTENDED_SECONDS=8.0
# DEBOUNCE_HARD_CAP_SECONDS=30.0

# How many raw recent messages (both sides) to pass as plain context to the LLM
# RAW_HISTORY_DEPTH=10

# Random delay before sending a reply (seconds) to feel more human-like
# REPLY_DELAY_MIN=1.0
# REPLY_DELAY_MAX=3.0
